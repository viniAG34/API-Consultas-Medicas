# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=
DEBUG=True
# ALLOWED_HOSTS: em ambientes rodando via Docker (staging/produção, ver SDD-07),
# inclua também "localhost,127.0.0.1" além do domínio real — o healthcheck do
# docker-compose.yml faz a requisição de dentro do próprio container, com
# cabeçalho Host sempre "localhost", nunca o domínio público. Sem isso, o
# Django rejeita a requisição do healthcheck com 400 (DisallowedHost).
# Ex.: ALLOWED_HOSTS=api-lacrei.dominio.com,localhost,127.0.0.1
ALLOWED_HOSTS=
CSRF_TRUSTED_ORIGINS=

# Banco de dados
# DATABASE_URL: usada em desenvolvimento local sem Docker (aponte para localhost).
# Dentro do docker-compose, o serviço `web` recebe DATABASE_URL montada
# automaticamente a partir dos POSTGRES_* abaixo (ver docker-compose.yml) —
# não é necessário preencher as duas fontes manualmente.
DATABASE_URL=postgres://usuario:senha@localhost:5432/lacrei
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SDD-04 — Segurança e autenticação
# Lista separada por vírgula de origens permitidas (nunca "*")
CORS_ALLOWED_ORIGINS=http://localhost:3000
